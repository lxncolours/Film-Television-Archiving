# 数据库配置（Docker 内使用 mysql 作为 host）
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=movie_archive

# TMDB API 配置（从 https://www.themoviedb.org/settings/api 获取，必填）
TMDB_API_KEY=your_tmdb_api_key_here

# Redis 配置（Docker 内使用 redis 作为 host）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 代理配置（如需）
# HTTP_PROXY=http://127.0.0.1:6789
# HTTPS_PROXY=http://127.0.0.1:6789

# 加密密钥（用于加密存储 TMDB API Key 和代理配置到数据库）
# 请设置为一个长度至少 32 位的随机字符串
# ENCRYPTION_KEY=your_random_encryption_key_here_change_me

# 服务器端口
PORT=5280

# Docker Compose 启动方式：
#   TMDB_API_KEY=your_key docker compose up -d
# 或创建 .env 文件后：
#   docker compose up -d
